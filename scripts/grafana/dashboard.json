{
  "__inputs": [
    {
      "name": "DS_PROMETHEUS",
      "label": "Grafana Cloud metrics (Prometheus/Mimir)",
      "description": "The Grafana Cloud stack's built-in Prometheus datasource that receives macquiz's OTLP metrics (docs/10-operations.md section 2).",
      "type": "datasource",
      "pluginId": "prometheus"
    }
  ],
  "__requires": [
    { "type": "grafana", "id": "grafana", "name": "Grafana", "version": "10.0.0" },
    { "type": "datasource", "id": "prometheus", "name": "Prometheus", "version": "1.0.0" }
  ],
  "title": "MacQuiz - Live Ops",
  "description": "docs/10-operations.md section 2's four key series: autosave latency, WebSocket connection count, queue lag, and violation/kick event rates. Import via Grafana Cloud's Dashboards > New > Import, pasting this file or its JSON, then map DS_PROMETHEUS to the stack's Prometheus/Mimir datasource.",
  "schemaVersion": 39,
  "version": 1,
  "editable": true,
  "graphTooltip": 1,
  "timezone": "browser",
  "time": { "from": "now-6h", "to": "now" },
  "refresh": "30s",
  "tags": ["macquiz"],
  "panels": [
    {
      "id": 1,
      "title": "Autosave latency (p95)",
      "description": "docs/10 section 3: warn > 200ms sustained 5m, page > 300ms sustained 5m during a live window.",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "fieldConfig": {
        "defaults": {
          "unit": "s",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 0.2 },
              { "color": "red", "value": 0.3 }
            ]
          }
        },
        "overrides": []
      },
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
          "expr": "histogram_quantile(0.95, sum(rate(macquiz_attempt_autosave_duration_seconds_bucket[5m])) by (le))",
          "legendFormat": "autosave p95"
        }
      ]
    },
    {
      "id": 2,
      "title": "Open WebSocket connections",
      "description": "macquiz.realtime.ws_connections - open teacher live-monitor sockets.",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "fieldConfig": { "defaults": { "unit": "short" }, "overrides": [] },
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
          "expr": "macquiz_realtime_ws_connections",
          "legendFormat": "ws connections"
        }
      ]
    },
    {
      "id": 3,
      "title": "Queue lag (oldest overdue River job)",
      "description": "docs/10 section 3: warn > 10s, page > 60s (deadline timers at risk). Same query /healthz uses, exported by both the app and worker processes.",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 8 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "fieldConfig": {
        "defaults": {
          "unit": "s",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 10 },
              { "color": "red", "value": 60 }
            ]
          }
        },
        "overrides": []
      },
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
          "expr": "macquiz_queue_lag_seconds",
          "legendFormat": "{{job}}"
        }
      ]
    },
    {
      "id": 4,
      "title": "Guardrail violations (rate, by type)",
      "description": "macquiz.attempt.violations - fullscreen/focus/clipboard reports.",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 8 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "fieldConfig": { "defaults": { "unit": "ops" }, "overrides": [] },
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
          "expr": "sum(rate(macquiz_attempt_violations_total[5m])) by (type)",
          "legendFormat": "{{type}}"
        }
      ]
    },
    {
      "id": 5,
      "title": "Kicks (rate)",
      "description": "macquiz.attempt.kicks - teacher/admin kicks of a live attempt.",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 16 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "fieldConfig": { "defaults": { "unit": "ops" }, "overrides": [] },
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
          "expr": "sum(rate(macquiz_attempt_kicks_total[5m]))",
          "legendFormat": "kicks"
        }
      ]
    },
    {
      "id": 6,
      "title": "Worker due-transitions (rate, by kind)",
      "description": "macquiz.worker.due_transitions - scheduler/deadline/grading pipeline making progress: quizzes_opened, quizzes_closed, attempts_auto_submitted, attempts_force_submitted, attempts_graded, results_released, quizzes_rolled_up.",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 16 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "fieldConfig": { "defaults": { "unit": "ops" }, "overrides": [] },
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
          "expr": "sum(rate(macquiz_worker_due_transitions_total[5m])) by (kind)",
          "legendFormat": "{{kind}}"
        }
      ]
    }
  ]
}
