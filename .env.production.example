# Template for the VM's /opt/macquiz/.env.production (docs/09-deployment.md
# section 4). Copy this file there, fill in real values, and never commit
# the filled-in copy (.gitignore already excludes .env.production).
#
# docker-compose.prod.yml passes this whole file via env_file: to postgres,
# app, and worker, so every var below must be set even though only some
# services read each one.

# --- Postgres ---
# MACQUIZ_DATABASE_URL below must embed the same user/password by hand -
# env_file values are not interpolated into each other.
POSTGRES_USER=macquiz
POSTGRES_PASSWORD=replace-with-a-generated-secret
POSTGRES_DB=macquiz

# --- App/worker (server/internal/config/config.go) ---
MACQUIZ_ADDR=:8080
MACQUIZ_ENV=production
MACQUIZ_DATABASE_URL=postgres://macquiz:replace-with-a-generated-secret@postgres:5432/macquiz?sslmode=disable
MACQUIZ_REDIS_URL=redis://redis:6379/0
# Signs JWT access tokens - generate a real random secret, do not reuse the
# dev-only default from config.go.
MACQUIZ_AUTH_SECRET=replace-with-a-generated-secret
# The Cloudflare Pages origin(s) the realtime /ws upgrade must accept from.
MACQUIZ_WS_ALLOWED_ORIGINS=https://macquiz.example.edu
MACQUIZ_IMPORT_DIR=/var/lib/macquiz/imports

# Only read once, by the manual `docker compose run --rm app bootstrap`
# step (docker-compose.prod.yml's header comment) - not used by serve/worker.
MACQUIZ_BOOTSTRAP_ADMIN_EMAIL=admin@example.edu
MACQUIZ_BOOTSTRAP_ADMIN_PASSWORD=replace-with-a-generated-secret
MACQUIZ_BOOTSTRAP_ADMIN_NAME=Administrator

# --- Image + Caddy (docker-compose.prod.yml, Caddyfile) ---
MACQUIZ_IMAGE=ghcr.io/your-github-org/macquiz-app
TAG=latest
DOMAIN=quiz-api.example.edu
