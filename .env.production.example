# Template for the VM's /opt/macquiz/.env.production (docs/09-deployment.md
# section 4). Copy this file there, fill in real values, and never commit
# the filled-in copy (.gitignore already excludes .env.production).
#
# docker-compose.prod.yml passes this whole file via env_file: to postgres,
# app, worker, and backup, so every var below must be set even though only
# some services read each one.

# --- Postgres ---
# MACQUIZ_DATABASE_URL below must embed the same user/password by hand -
# env_file values are not interpolated into each other.
POSTGRES_USER=macquiz
POSTGRES_PASSWORD=replace-with-a-generated-secret
POSTGRES_DB=macquiz

# --- App/worker (server/internal/config/config.go) ---
MACQUIZ_ADDR=:8080
MACQUIZ_ENV=production
MACQUIZ_DATABASE_URL=postgres://macquiz:replace-with-a-generated-secret@postgres:5432/macquiz?sslmode=disable
MACQUIZ_REDIS_URL=redis://redis:6379/0
# Signs JWT access tokens - generate a real random secret, do not reuse the
# dev-only default from config.go.
MACQUIZ_AUTH_SECRET=replace-with-a-generated-secret
# The Cloudflare Pages origin(s) the realtime /ws upgrade must accept from.
MACQUIZ_WS_ALLOWED_ORIGINS=https://macquiz.example.edu
MACQUIZ_IMPORT_DIR=/var/lib/macquiz/imports
# Grafana Cloud OTLP/HTTP metrics gateway (docs/10-operations.md section 2).
# Leave both blank to disable telemetry entirely (every instrument becomes a
# no-op) - safe for a first deploy before a Grafana Cloud account exists.
MACQUIZ_OTEL_EXPORTER_ENDPOINT=otlp-gateway-prod-xx-xxx-0.grafana.net/otlp
MACQUIZ_OTEL_EXPORTER_HEADERS=Authorization=Basic replace-with-base64-instanceid:token
# Resend API key for the email leg of assignment-change notifications
# (docs/09-deployment.md section 3: "Resend, 3k/month, $0"). Leave blank to
# disable email delivery entirely - the in-app user:{id}:notify channel
# still delivers the same quiz.assigned/quiz.unassigned event either way.
MACQUIZ_EMAIL_API_KEY=replace-with-a-resend-api-key
MACQUIZ_EMAIL_FROM=notify@example.edu
MACQUIZ_EMAIL_FROM_NAME=MacQuiz

# Only read once, by the manual `docker compose run --rm app bootstrap`
# step (docker-compose.prod.yml's header comment) - not used by serve/worker.
MACQUIZ_BOOTSTRAP_ADMIN_EMAIL=admin@example.edu
MACQUIZ_BOOTSTRAP_ADMIN_PASSWORD=replace-with-a-generated-secret
MACQUIZ_BOOTSTRAP_ADMIN_NAME=Administrator

# --- Image + Caddy (docker-compose.prod.yml, Caddyfile) ---
MACQUIZ_IMAGE=ghcr.io/your-github-org/macquiz-app
TAG=latest
DOMAIN=quiz-api.example.edu

# --- Nightly backup (docs/10-operations.md section 1; scripts/backup) ---
# R2 bucket dedicated to backups, with object versioning turned on (a
# bucket-level R2 setting, done once at provisioning time, not by this
# repo) as the belt against a bad prune. AWS_ACCESS_KEY_ID/SECRET are an
# R2 API token scoped to only this bucket.
BACKUP_R2_BUCKET=macquiz-backups
BACKUP_R2_ENDPOINT=https://replace-with-your-account-id.r2.cloudflarestorage.com
AWS_ACCESS_KEY_ID=replace-with-an-r2-access-key-id
AWS_SECRET_ACCESS_KEY=replace-with-an-r2-secret-access-key
# Retention: 7 daily + 8 weekly dumps, pruned by the same nightly job.
BACKUP_DAILY_KEEP=7
BACKUP_WEEKLY_KEEP=8
